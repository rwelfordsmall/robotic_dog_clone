<?xml version="1.0"?>
<robot name="dog" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- ──────────────────────────────────────────────────────────────
       Materials — Virginia Tech brand colors
         Chicago Maroon  #861F41  → upper legs
         Burnt Orange    #E5751F  → lower legs
         Hokie Stone     #75787B  → base / body
  ────────────────────────────────────────────────────────────── -->
  <material name="dark_grey">
    <color rgba="0.20 0.20 0.20 1.0"/>
  </material>

  <material name="hokie_stone">
    <color rgba="0.459 0.471 0.482 1.0"/>
  </material>

  <material name="chicago_maroon">
    <color rgba="0.525 0.122 0.255 1.0"/>
  </material>

  <material name="burnt_orange">
    <color rgba="0.898 0.459 0.122 1.0"/>
  </material>

  <!-- ──────────────────────────────────────────────────────────────
       Base link
  ────────────────────────────────────────────────────────────── -->
  <link name="base_link">
    <inertial>
      <origin xyz="0.0324578171199918 -0.00107208054772986 -0.0532934197949659" rpy="0 0 0"/>
      <mass value="9.55580178099991"/>
      <inertia
        ixx="0.028878887728372"
        ixy="-5.32734038649637E-05"
        ixz="-9.99548284777576E-05"
        iyy="0.0328205453767607"
        iyz="-2.0005331957631E-05"
        izz="0.0484423164334583"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="file://$(find dog)/urdf/meshes/base_link.STL"/>
      </geometry>
      <material name="hokie_stone"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="file://$(find dog)/urdf/meshes/base_link_collisional.STL"/>
      </geometry>
    </collision>
  </link>

  <!-- IMU frame -->
  <link name="imu_link">
    <inertial>
      <mass value="0.001"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="1e-6" ixy="0" ixz="0"
              iyy="1e-6" iyz="0"
              izz="1e-6"/>
    </inertial>
  </link>
  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="imu_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- LiDAR frame -->
  <link name="lidar_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.370"/>
      <inertia
        ixx="3.4e-4" ixy="0" ixz="0"
        iyy="3.4e-4" iyz="0"
        izz="2.2e-4"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.060 0.060 0.087"/>
      </geometry>
      <material name="dark_grey"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.060 0.060 0.087"/>
      </geometry>
    </collision>
  </link>

  <joint name="lidar_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="lidar_link"/>
    <origin xyz="0.284282580961245 9.01880488845888E-05 0.0962574459982149" rpy="0 0 0"/>
  </joint>

  <!-- Camera frame -->
  <link name="camera_link"/>
  <joint name="camera_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="camera_link"/>
    <origin xyz="0.352482816608291 0.000734336789502524 -0.0246227904334168" rpy="0 0 0"/>
  </joint>

  <!-- ──────────────────────────────────────────────────────────────
       Gazebo: Hokuyo-style lidar sensor
  ────────────────────────────────────────────────────────────── -->
  <gazebo reference="lidar_link">
    <sensor name="hokuyo_lidar" type="lidar">
      <always_on>1</always_on>
      <update_rate>10</update_rate>
      <topic>/scan</topic>
      <gz_frame_id>lidar_link</gz_frame_id>
      <lidar>
        <scan>
          <horizontal>
            <samples>360</samples>
            <resolution>1</resolution>
            <min_angle>-2.356</min_angle>
            <max_angle>2.356</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.10</min>
          <max>30.0</max>
          <resolution>0.01</resolution>
        </range>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.01</stddev>
        </noise>
      </lidar>
    </sensor>
  </gazebo>

  <!-- ──────────────────────────────────────────────────────────────
       8-DOF leg macro
       Upper leg → Chicago Maroon
       Lower leg → Burnt Orange
  ────────────────────────────────────────────────────────────── -->
  <xacro:macro name="cad_leg" params="
      name
      shoulder_xyz
      knee_xyz
      upper_mesh
      upper_collision_mesh
      upper_com_xyz
      upper_mass
      upper_ixx upper_ixy upper_ixz upper_iyy upper_iyz upper_izz
      lower_mesh
      lower_collision_mesh
      lower_com_xyz
      lower_mass
      lower_ixx lower_ixy lower_ixz lower_iyy lower_iyz lower_izz">

    <joint name="${name}_shoulder_joint" type="revolute">
      <parent link="base_link"/>
      <child  link="${name}_upper_leg_link"/>
      <origin xyz="${shoulder_xyz}" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <limit lower="-2.094" upper="2.094" effort="8" velocity="4.19"/>
      <dynamics damping="0.1" friction="0.0"/>
    </joint>

    <link name="${name}_upper_leg_link">
      <inertial>
        <origin xyz="${upper_com_xyz}" rpy="0 0 0"/>
        <mass value="${upper_mass}"/>
        <inertia
          ixx="${upper_ixx}" ixy="${upper_ixy}" ixz="${upper_ixz}"
          iyy="${upper_iyy}" iyz="${upper_iyz}"
          izz="${upper_izz}"/>
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <mesh filename="file://$(find dog)/urdf/meshes/${upper_mesh}"/>
        </geometry>
        <material name="chicago_maroon"/>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <mesh filename="file://$(find dog)/urdf/meshes/${upper_collision_mesh}"/>
        </geometry>
      </collision>
    </link>

    <joint name="${name}_knee_joint" type="revolute">
      <parent link="${name}_upper_leg_link"/>
      <child  link="${name}_lower_leg_link"/>
      <origin xyz="${knee_xyz}" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <limit lower="-2.4" upper="2.4" effort="8" velocity="4.19"/>
      <dynamics damping="0.1" friction="0.0"/>
    </joint>

    <link name="${name}_lower_leg_link">
      <inertial>
        <origin xyz="${lower_com_xyz}" rpy="0 0 0"/>
        <mass value="${lower_mass}"/>
        <inertia
          ixx="${lower_ixx}" ixy="${lower_ixy}" ixz="${lower_ixz}"
          iyy="${lower_iyy}" iyz="${lower_iyz}"
          izz="${lower_izz}"/>
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <mesh filename="file://$(find dog)/urdf/meshes/${lower_mesh}"/>
        </geometry>
        <material name="burnt_orange"/>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <mesh filename="file://$(find dog)/urdf/meshes/${lower_collision_mesh}"/>
        </geometry>
      </collision>
    </link>

  </xacro:macro>

  <!-- Front Right = CAD leg2 -->
  <xacro:cad_leg
    name="fr"
    shoulder_xyz="0.324 -0.116499949318977 -0.0675412498731288"
    knee_xyz="0 -0.100454686079827 -0.218251817964039"
    upper_mesh="leg2_upper_link.STL"
    upper_collision_mesh="leg2_upper_link_collisional.STL"
    upper_com_xyz="0.000127800307332776 -0.0766213988151565 -0.0599664662260584"
    upper_mass="0.637697073092088"
    upper_ixx="0.00167741793065014"
    upper_ixy="-3.35293034128317E-09"
    upper_ixz="-2.13123778687523E-06"
    upper_iyy="0.00180852251444854"
    upper_iyz="3.99916830759616E-05"
    upper_izz="0.000238016619270677"
    lower_mesh="leg2_lower_link.STL"
    lower_collision_mesh="leg2_lower_link_collisional.STL"
    lower_com_xyz="-1.80707555090878E-06 0.000293120445839512 -0.122867406862322"
    lower_mass="0.138600070454872"
    lower_ixx="0.000410120014711362"
    lower_ixy="4.64383968889363E-11"
    lower_ixz="-2.11827782414142E-10"
    lower_iyy="0.000415045952434337"
    lower_iyz="2.9354653978298E-06"
    lower_izz="1.7742930568453E-05"/>

  <!-- Front Left = CAD leg1 -->
  <xacro:cad_leg
    name="fl"
    shoulder_xyz="0.324 0.116499322559436 -0.0669587516936535"
    knee_xyz="0 0.101544682673132 -0.217746819542348"
    upper_mesh="leg1_upper_link.STL"
    upper_collision_mesh="leg1_upper_link_collisional.STL"
    upper_com_xyz="-0.000328889665845748 0.0769193925083935 -0.0592310111145546"
    upper_mass="0.637697073092139"
    upper_ixx="0.001682415664332"
    upper_ixy="-2.01178366091829E-08"
    upper_ixz="-8.0890527186563E-07"
    upper_iyy="0.00180888301272588"
    upper_iyz="-3.21012746181014E-05"
    upper_izz="0.000232658387311611"
    lower_mesh="leg1_lower_link.STL"
    lower_collision_mesh="leg1_lower_link_collisional.STL"
    lower_com_xyz="1.80716266513434E-06 0.000321216376702682 -0.122867335712219"
    lower_mass="0.138600072096363"
    lower_ixx="0.000410120019152843"
    lower_ixy="4.54735361281021E-11"
    lower_ixz="2.11671521332614E-10"
    lower_iyy="0.000415065379224809"
    lower_iyz="-9.4884052073769E-07"
    lower_izz="1.7723509254257E-05"/>

  <!-- Rear Right = CAD leg3 -->
  <xacro:cad_leg
    name="rr"
    shoulder_xyz="-0.324 -0.116500000882996 -0.0675000000006123"
    knee_xyz="0 -0.101000000000619 -0.217999999999799"
    upper_mesh="leg3_upper_link.STL"
    upper_collision_mesh="leg3_upper_link_collisional.STL"
    upper_com_xyz="0.000213744423748441 -0.076771075071646 -0.0592143076585741"
    upper_mass="0.63769707309038"
    upper_ixx="0.00167901538529498"
    upper_ixy="-1.44334103136461E-08"
    upper_ixz="2.95457124567797E-06"
    upper_iyy="0.0018087126560125"
    upper_iyz="3.60274341620652E-05"
    upper_izz="0.000236229023058977"
    lower_mesh="leg3_lower_link.STL"
    lower_collision_mesh="leg3_lower_link_collisional.STL"
    lower_com_xyz="-1.80751626877029E-06 -1.40505594015405E-05 -0.122867754922063"
    lower_mass="0.138600071390485"
    lower_ixx="0.000410120015739175"
    lower_ixy="4.59990229103003E-11"
    lower_ixz="-2.12414780803217E-10"
    lower_iyy="0.000415058148288933"
    lower_iyz="1.94216353348255E-06"
    lower_izz="1.77307364574072E-05"/>

  <!-- Rear Left = CAD leg4 -->
  <xacro:cad_leg
    name="rl"
    shoulder_xyz="-0.324 0.116499999117003 -0.0675000000009629"
    knee_xyz="0 0.101 -0.218"
    upper_mesh="leg4_upper_link.STL"
    upper_collision_mesh="leg4_upper_link_collisional.STL"
    upper_com_xyz="-9.75042667739068E-05 0.0767710750714986 -0.0597856696530003"
    upper_mass="0.637697073090724"
    upper_ixx="0.00167704645928537"
    upper_ixy="-6.65327760560173E-09"
    upper_ixz="1.68413403388964E-06"
    upper_iyy="0.00180871265601245"
    upper_iyz="-3.60656754427788E-05"
    upper_izz="0.000238197949068602"
    lower_mesh="leg4_lower_link.STL"
    lower_collision_mesh="leg4_lower_link_collisional.STL"
    lower_com_xyz="1.80678219541264E-06 1.40454489447328E-05 -0.122867755442078"
    lower_mass="0.138600070371376"
    lower_ixx="0.000410120013926268"
    lower_ixy="4.58923722545058E-11"
    lower_ixz="2.10488295534875E-10"
    lower_iyy="0.000415058145505495"
    lower_iyz="-1.94219086793343E-06"
    lower_izz="1.77307368033845E-05"/>

  <!-- ──────────────────────────────────────────────────────────────
       ros2_control hardware interface
  ────────────────────────────────────────────────────────────── -->
  <ros2_control name="GazeboSimSystem" type="system">
    <hardware>
      <plugin>ign_ros2_control/IgnitionSystem</plugin>
    </hardware>

    <joint name="fr_shoulder_joint">
      <command_interface name="position"/>
      <state_interface name="position"><param name="initial_value">0.6112</param></state_interface>
      <state_interface name="velocity"/>
    </joint>
    <joint name="fr_knee_joint">
      <command_interface name="position"/>
      <state_interface name="position"><param name="initial_value">-1.2224</param></state_interface>
      <state_interface name="velocity"/>
    </joint>

    <joint name="fl_shoulder_joint">
      <command_interface name="position"/>
      <state_interface name="position"><param name="initial_value">0.6112</param></state_interface>
      <state_interface name="velocity"/>
    </joint>
    <joint name="fl_knee_joint">
      <command_interface name="position"/>
      <state_interface name="position"><param name="initial_value">-1.2224</param></state_interface>
      <state_interface name="velocity"/>
    </joint>

    <joint name="rr_shoulder_joint">
      <command_interface name="position"/>
      <state_interface name="position"><param name="initial_value">0.6112</param></state_interface>
      <state_interface name="velocity"/>
    </joint>
    <joint name="rr_knee_joint">
      <command_interface name="position"/>
      <state_interface name="position"><param name="initial_value">-1.2224</param></state_interface>
      <state_interface name="velocity"/>
    </joint>

    <joint name="rl_shoulder_joint">
      <command_interface name="position"/>
      <state_interface name="position"><param name="initial_value">0.6112</param></state_interface>
      <state_interface name="velocity"/>
    </joint>
    <joint name="rl_knee_joint">
      <command_interface name="position"/>
      <state_interface name="position"><param name="initial_value">-1.2224</param></state_interface>
      <state_interface name="velocity"/>
    </joint>
  </ros2_control>

  <!-- ign_ros2_control plugin -->
  <gazebo>
    <plugin filename="ign_ros2_control-system"
            name="gz_ros2_control::GazeboSimROS2ControlPlugin">
      <parameters>$(find dog)/config/ros2_controllers.yaml</parameters>
      <ros>
        <namespace>/</namespace>
      </ros>
    </plugin>
  </gazebo>

  <!-- Gazebo: ground-truth odometry -->
  <gazebo>
    <plugin filename="ignition-gazebo-odometry-publisher-system"
            name="ignition::gazebo::systems::OdometryPublisher">
      <odom_frame>odom</odom_frame>
      <robot_base_frame>base_link</robot_base_frame>
      <odom_publish_frequency>50</odom_publish_frequency>
      <dimensions>2</dimensions>
    </plugin>
  </gazebo>

  <!-- IMU sensor -->
  <gazebo reference="imu_link">
    <sensor name="imu_sensor" type="imu">
      <always_on>1</always_on>
      <update_rate>50</update_rate>
      <topic>/imu/data</topic>
      <gz_frame_id>imu_link</gz_frame_id>
      <imu>
        <angular_velocity>
          <x><noise type="gaussian"><mean>0.0</mean><stddev>2e-4</stddev></noise></x>
          <y><noise type="gaussian"><mean>0.0</mean><stddev>2e-4</stddev></noise></y>
          <z><noise type="gaussian"><mean>0.0</mean><stddev>2e-4</stddev></noise></z>
        </angular_velocity>
        <linear_acceleration>
          <x><noise type="gaussian"><mean>0.0</mean><stddev>0.017</stddev></noise></x>
          <y><noise type="gaussian"><mean>0.0</mean><stddev>0.017</stddev></noise></y>
          <z><noise type="gaussian"><mean>0.0</mean><stddev>0.017</stddev></noise></z>
        </linear_acceleration>
      </imu>
    </sensor>
  </gazebo>

</robot>
